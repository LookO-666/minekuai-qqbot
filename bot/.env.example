# ============================================================
# 麦块联机 QQ Bot 配置文件
# 把这个文件复制为 .env，然后填写下面的配置
# ============================================================

# ----------------- nonebot 基础配置 -----------------
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO

# 反向 WebSocket 路径（NapCat 那边要填一致的）
# 默认就好，一般不用改
ONEBOT_WS_URLS=["ws://127.0.0.1:8080/onebot/v11/ws"]

# 机器人指令前缀（留空则不需要前缀）
# 留空: 群里发"开服"就触发
# 填 "/": 群里要发"/开服"才触发
COMMAND_START=[""]


# ----------------- 麦块联机配置（兼容字段，可选） -----------------
# 新版改成多服务器模型，配置存在 SQLite 里，群里通过『添加服务器』管理。
# 下面这三个字段是给旧版单台部署留的兼容入口：
# 启动时如果数据库为空且这三个都填了，会自动导入为名为『default』的服务器；
# 之后请用『添加服务器』『删除服务器』『更新token』指令管理，这些字段会被忽略。
# 如果你是新部署，可以全部留空，启动后直接在群里发『添加服务器』。

MINEKUAI_TOKEN=
MINEKUAI_CLIENT_ID=
MINEKUAI_CARD_ID=



# ----------------- 权限和限流 -----------------

# 允许使用机器人的 QQ 群号（多个用英文逗号分隔）
# 例: ALLOWED_GROUPS=[123456789, 987654321]
ALLOWED_GROUPS=[123456789]

# 允许使用机器人的 QQ 号白名单（多个用英文逗号分隔）
# 留空 [] 表示允许群里所有人使用
# 例: ALLOWED_USERS=[12345678, 87654321]
ALLOWED_USERS=[]

# 高权限命令管理员（账号/服务器配置、控制台、日志、重启等）
ADMIN_USERS=[12345678]

# 是否让 ALLOWED_GROUPS 白名单群内的所有可用成员拥有管理员权限
# 默认 false；开启前请确认群成员均可信
ADMIN_ALL_GROUP_MEMBERS=false

# Fernet 加密密钥；首次部署生成后必须妥善备份，不可随意更换
# python3 -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=

# 操作冷却时间（秒）—— 同一个人在 N 秒内不能重复发同一指令
COMMAND_COOLDOWN=5

# 关服是否需要二次确认（防止误操作把别人的游戏关了）
# true: 发"关服"后需要再回复"确认关服"才执行
# false: 一键关闭
STOP_NEED_CONFIRM=true
# 后台轮询周期（秒，最小 5）；用于状态、资源和回退日志轮询
POLL_INTERVAL_SECONDS=30


# ----------------- 群服互通和自动播报 -----------------

# 玩家加入/离开/死亡/成就及聊天日志解析总开关
EVENT_BROADCAST=true

# 是否播报玩家加入/离开（死亡和成就仍由 EVENT_BROADCAST 总开关控制）
BROADCAST_JOIN_LEAVE=true

# 优先使用 Pterodactyl WebSocket 实时读取控制台；关闭后轮询 latest.log
REALTIME_CONSOLE=true

# Minecraft ↔ QQ 群双向聊天桥
CHAT_BRIDGE=true
CHAT_MC_TO_QQ=true
CHAT_QQ_TO_MC=true


# ----------------- 资源告警 -----------------

RESOURCE_ALERT=true
CPU_ALERT_PERCENT=95
MEM_ALERT_PERCENT=92
ALERT_SUSTAINED_TICKS=3
ALERT_COOLDOWN_MINUTES=30
